# OS / editor cruft
.DS_Store
Thumbs.db
*.tmp
*.temp

# Local agent workspace
.claude/

# Dependency/build caches
node_modules/
.dist/
dist/
build/
.cache/
.vercel

# Visual regression: ignore every per-run artifact but KEEP the committed baselines.
# (The bare `screenshots/` rule used to swallow the baselines too — keep the
# `screenshots/*` + negation form so screenshots/baseline/ is tracked for VRT.)
screenshots/*
!screenshots/baseline/
!screenshots/baseline/**

# Large unserved source/staging files & local agent workspace.
# attached_assets/ is the git-ignored masters folder (backed up, then removed);
# the rule stays so any regenerated copy is never committed.
attached_assets/
.local/
